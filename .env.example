# ── Namen für die Knöpfe (kommasepariert, 5–6 Stück) ──────────────────────────
NAMES=Anna,Bea,Chris,David,Eva,Felix,Sarah

# ── Drucker / Etikette ────────────────────────────────────────────────────────
# DK-22210 = 29 mm Endlosband → brother_ql Label "29"
LABEL_SIZE=29
PRINTER_MODEL=QL-800
PRINTER_BACKEND=linux_kernel
PRINTER_DEVICE=file:///dev/usb/lp0

# Druckbare Breite quer zum 29-mm-Band in Pixel (300 dpi).
TAPE_WIDTH_PX=306

# Drehung. "0" = Zeilen quer über die Breite. Auf "180" ändern, falls kopfüber.
ROTATE=0

# Grösste Schrift; wird zusätzlich verkleinert, damit jede Zeile in die Breite passt.
# Höher = grösser (bis die Breite limitiert), niedriger = kleiner.
MAX_FONT=80

# Mindest-Etikettenlänge in px (QL-800 braucht >= 150). Rand pro Seite.
MIN_LABEL_LEN=160
MARGIN_PX=16

# ── Entsorgungs-Etikett ("Wird entsorgt am: …") ───────────────────────────────
# Entsorgungsdatum = heute + DISPOSAL_DAYS.
DISPOSAL_DAYS=5
# Rot-Druck. Erfordert die Zweifarb-Rolle DK-22251 (schwarz/rot, 62 mm)!
# Mit der 29-mm-Rolle bleibt der Text schwarz. Zum Aktivieren beide Zeilen setzen:
#   DISPOSAL_RED=1
#   DISPOSAL_LABEL_SIZE=62
DISPOSAL_RED=0
DISPOSAL_LABEL_SIZE=29
# Weisser Text auf schwarzem (bzw. mit Rot-Rolle rotem) Grund → auffälliger.
# Auf 0 für normalen Text auf weissem Grund.
DISPOSAL_INVERT=1

# ── Web ───────────────────────────────────────────────────────────────────────
PORT=5000
