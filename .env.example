# ── Namen für die Knöpfe (kommasepariert, 5–6 Stück) ──────────────────────────
NAMES=Anna,Bea,Chris,David,Eva,Felix

# ── Drucker / Etikette ────────────────────────────────────────────────────────
# DK-22210 = 29 mm Endlosband → brother_ql Label "29"
LABEL_SIZE=29
PRINTER_MODEL=QL-800
PRINTER_BACKEND=linux_kernel
PRINTER_DEVICE=file:///dev/usb/lp0

# Druckbare Breite quer zum 29-mm-Band in Pixel (300 dpi).
TAPE_WIDTH_PX=306

# Drehung. "0" = Zeilen quer über die Breite. Auf "180" ändern, falls kopfüber.
ROTATE=0

# Grösste Schrift; wird zusätzlich verkleinert, damit jede Zeile in die Breite passt.
# Höher = grösser (bis die Breite limitiert), niedriger = kleiner.
MAX_FONT=80

# Mindest-Etikettenlänge in px (QL-800 braucht >= 150). Rand pro Seite.
MIN_LABEL_LEN=160
MARGIN_PX=16

# ── Web ───────────────────────────────────────────────────────────────────────
PORT=5000
