# ── Namen für die Knöpfe (kommasepariert, 5–6 Stück) ──────────────────────────
NAMES=Anna,Bea,Chris,David,Eva,Felix

# ── Drucker / Etikette ────────────────────────────────────────────────────────
# DK-22210 = 29 mm Endlosband → brother_ql Label "29"
LABEL_SIZE=29
PRINTER_MODEL=QL-800
PRINTER_BACKEND=linux_kernel
PRINTER_DEVICE=file:///dev/usb/lp0

# Druckbare Breite quer zum 29-mm-Band in Pixel (300 dpi).
TAPE_WIDTH_PX=306

# Drehung fürs Band. "90" Standard; auf "270" ändern, falls Schrift kopfsteht.
ROTATE=90

# Ziel-Texthöhe in Pixel (306 px = volle Bandbreite). Zum Justieren der Grösse:
#   SINGLE_LINE_H = Nur-Datum-Etikett (eine Zeile)
#   DOUBLE_LINE_H = Datum + Name (zwei Zeilen) – gilt pro Zeile
SINGLE_LINE_H=150
DOUBLE_LINE_H=120

# ── Web ───────────────────────────────────────────────────────────────────────
PORT=5000
